PORT=3000
APP_NAME=IndiaNikah AI Content Hub
APP_VERSION=0.1.0
NODE_ENV=development
DATABASE_URL="file:./prisma/dev.db"

# Production IndiaNikah MySQL - SELECT-only account.
# Local development through SSH tunnel: host 127.0.0.1, port 3307.
# VPS deployment: host 127.0.0.1, port 3306.
PROD_DB_HOST=127.0.0.1
PROD_DB_PORT=3307
PROD_DB_NAME=django
PROD_DB_USER=contenthub_reader
PROD_DB_PASSWORD=

# Disabled by default locally. Enable on the VPS after deployment.
PROFILE_IMPORT_CRON_ENABLED=false
PROFILE_IMPORT_CRON="0 8 * * *"
PROD_DB_POOL_SIZE=3

# Telegram publishing
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@IndiaNikah
TELEGRAM_PUBLISH_ENABLED=false
AI_GENERATION_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

PUBLISH_PLATFORMS=TELEGRAM
BOOK_REPUBLISH_AFTER_DAYS=90
GUIDELINE_REPUBLISH_AFTER_DAYS=60
BLOG_REPUBLISH_AFTER_DAYS=180
CONTENT_QUEUE_CRON_ENABLED=false
CONTENT_QUEUE_CRON="15 * * * *"
QUEUE_TARGET_READY=6
QUEUE_AUTO_PUBLISH=false

FACEBOOK_PUBLISH_ENABLED=false
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Milestone 2 profile importer tuning
PROFILE_IMPORT_BATCH_SIZE=250
PROFILE_IMPORT_MAX_BATCHES=20
PROD_DB_QUEUE_LIMIT=20
PROD_DB_CONNECT_TIMEOUT_MS=10000

# Milestone 3 generation
# AUTO uses OpenAI only when enabled and configured; otherwise safe local templates.
MILESTONE3_DEFAULT_PROVIDER=AUTO
